# ═══════════════════════════════════════════════════
# LOCAWAVE — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# ═══════════════════════════════════════════════════

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Anthropic (Claude API — pour OCR Wave et rapports IA)
ANTHROPIC_API_KEY=sk-ant-xxx

# Twilio (WhatsApp API)
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxxxx
WHATSAPP_FROM=whatsapp:+14155238886

# ─── PSP — Encaissement loyers (Phase 2) ───
# Fournisseur actif : simulation | paydunya | cinetpay  (défaut: simulation, aucun compte requis)
PSP_PROVIDER=simulation
# Secret de signature des webhooks (HMAC-SHA256). OBLIGATOIRE même en simulation.
# À configurer AUSSI côté Supabase Edge Functions (secret PSP_WEBHOOK_SECRET).
PSP_WEBHOOK_SECRET=change-me-long-random-string
# PayDunya (si PSP_PROVIDER=paydunya) — https://paydunya.com
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_TOKEN=
PAYDUNYA_MODE=live
# CinetPay (si PSP_PROVIDER=cinetpay) — https://cinetpay.com
CINETPAY_API_KEY=
CINETPAY_SITE_ID=

# Resend (Emails transactionnels)
RESEND_API_KEY=re_xxx

# Sentry (Monitoring erreurs)
SENTRY_DSN=https://xxx@sentry.io/xxx
